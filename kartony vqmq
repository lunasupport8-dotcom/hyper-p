                }
            },

            openVSQD(path) {
                let { parentNode, name } = this.vfs.getParentNodeAndName(path);
                let node = this.vfs.getNode(path);
                
                // Create file dynamically if it does not exist
                if (!node) {
                    if (parentNode && parentNode.type === 'dir') {
                        let defaultContent = '// Write JS code here...\n';
                        if (name.endsWith('.py')) defaultContent = '# Write Python code here...\n';
                        if (name.endsWith('.html')) defaultContent = '<!-- Write HTML here -->\n';

                        parentNode.contents[name] = { type: 'file', content: defaultContent };
                        node = parentNode.contents[name];
                        this.renderDesktop();
                        if (this.currentFileMgrPath === this.vfs.resolvePath('/', path).substring(0, path.lastIndexOf('/'))) {
                            this.renderFileManager(this.currentFileMgrPath);
                        }
                    } else {
                        this.alert('Error', 'Cannot create file here.');
                        return;
                    }
                }
                
                this.currentVSQDPath = path;
                document.getElementById('vsqd-title').textContent = name;
                document.getElementById('vsqd-textarea').value = node.content || '';
                document.getElementById('vsqd-status').textContent = 'Ready.';
                document.getElementById('vsqd-console').innerHTML = ''; // clear previous output
                
                const win = document.getElementById('vsqd-window');
                win.classList.remove('hidden');
                win.classList.add('flex');
                win.dispatchEvent(new Event('mousedown')); // Bring the editor to the front
            },
            
            saveVSQD() {
                if (!this.currentVSQDPath) return;
                let node = this.vfs.getNode(this.currentVSQDPath);
                if (node && node.type === 'file') {
                    node.content = document.getElementById('vsqd-textarea').value;
                    document.getElementById('vsqd-status').textContent = 'File saved.';
                    if (this.terminal) {
                        this.terminal.print(`Saved changes to ${this.currentVSQDPath}`, 'success');
                    }
                    setTimeout(() => {
                        document.getElementById('vsqd-status').textContent = 'Ready.';
                    }, 2000);
                }
            },

            runVSQD() {
                const code = document.getElementById('vsqd-textarea').value;
                const consoleOut = document.getElementById('vsqd-console');
                const path = this.currentVSQDPath || 'untitled';
                
                if (path.endsWith('.html')) {
                    consoleOut.innerHTML += `\n<span class="text-blue-400">> Launching Browser for ${path}...</span>\n`;
                    this.openBrowser(code, path);
                    consoleOut.scrollTop = consoleOut.scrollHeight;
                    return;
                }

                consoleOut.innerHTML += `\n<span class="text-blue-400">> Running ${path}...</span>\n`;
                
                if (path.endsWith('.py')) {
                    Sk.configure({
                        output: function(text) {
                            const cleanText = text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
                            consoleOut.innerHTML += cleanText;
                        },
                        read: function(x) {
                            if (Sk.builtinFiles === undefined || Sk.builtinFiles["files"][x] === undefined)
                                throw "File not found: '" + x + "'";
                            return Sk.builtinFiles["files"][x];
                        }
                    });
                    Sk.misceval.asyncToPromise(function() {
                        return Sk.importMainWithBody("<stdin>", false, code, true);
                    }).then(function() {
                        consoleOut.innerHTML += `\n<span class="text-green-400">[Program finished]</span>\n`;
                        consoleOut.scrollTop = consoleOut.scrollHeight;
                    }, function(err) {
                        consoleOut.innerHTML += `<span class="text-red-500">[Error] ${err.toString()}</span>\n`;
                        consoleOut.scrollTop = consoleOut.scrollHeight;
                    });
                    return;
                }

                // Default to JavaScript
                // Temporarily override console.log to print to our VS QD console
                const originalLog = console.log;
                console.log = (...args) => {
                    const text = args.map(a => typeof a === 'object' ? JSON.stringify(a) : a).join(' ');
                    consoleOut.innerHTML += `${text}\n`;
                };

                try {
                    // Evaluate code in sandbox scope
                    let result = eval(code);
                    if (result !== undefined) {
                        consoleOut.innerHTML += `<span class="text-slate-400"><- ${result}</span>\n`;
                    }
                } catch (e) {
                    consoleOut.innerHTML += `<span class="text-red-500">[Error] ${e.message}</span>\n`;
                }

                // Restore real console.log and auto-scroll
                console.log = originalLog;
                consoleOut.scrollTop = consoleOut.scrollHeight;
            },
            
