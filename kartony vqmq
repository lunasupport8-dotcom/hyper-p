                    const icon = document.createElement('div');
                    icon.id = 'taskbar-term';
                    icon.className = 'px-3 py-1 bg-slate-700 rounded text-xs border-b-2 border-blue-500 flex items-center gap-2 cursor-pointer hover:bg-slate-600 transition-colors';
                    icon.innerHTML = '<span>💻</span> Terminal';
