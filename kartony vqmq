            fileMgrGoUp() {
                if (this.currentFileMgrPath === '/') return;
                let parts = this.currentFileMgrPath.split('/').filter(p => p !== '');
                parts.pop();
                let parentPath = '/' + parts.join('/');
                this.openFileManager(parentPath);
