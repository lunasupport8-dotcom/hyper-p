<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WebOS Linux Simulator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Add Skulpt for Python Execution -->
    <script src="https://cdn.jsdelivr.net/npm/skulpt@1.2.0/dist/skulpt.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/skulpt@1.2.0/dist/skulpt-stdlib.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&display=swap');

        body {
            margin: 0;
            overflow: hidden;
            background-color: #0f172a;
            color: white;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        .terminal-font {
            font-family: 'Fira Code', monospace;
        }

        /* Custom Scrollbar for Terminal */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1e293b; 
        }
        ::-webkit-scrollbar-thumb {
            background: #475569; 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #64748b; 
        }

        .boot-screen {
            position: absolute;
            inset: 0;
            background: black;
            color: #d1d5db;
            z-index: 50;
            padding: 20px;
            display: flex;
            flex-direction: column;
            transition: opacity 0.5s ease;
        }

        .window-shadow {
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.1);
        }
        
        .desktop-icon:hover {
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 0.5rem;
        }
    </style>
</head>
<body class="h-screen w-screen flex flex-col relative select-none">

    <!-- Fake Boot Screen -->
    <div id="boot-screen" class="boot-screen terminal-font text-sm">
        <div id="boot-text"></div>
    </div>

    <!-- Desktop Background -->
    <div id="desktop-bg" class="absolute inset-0 bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 z-0 bg-cover bg-center transition-all duration-500">
        <!-- Grid pattern overlay -->
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>
    </div>

    <!-- Hidden File Upload -->
    <input type="file" id="sys-file-upload" class="hidden" accept="image/*" onchange="os.handleFileUpload(event)">

    <!-- Desktop Icons -->
    <div id="desktop-icons-container" class="relative z-10 p-4 flex flex-col gap-4 flex-wrap h-[calc(100vh-4rem)] content-start">
        <!-- Rendered dynamically by JS -->
    </div>

    <!-- Terminal Window -->
    <div id="terminal-window" class="absolute hidden flex-col bg-slate-900 border border-slate-700 rounded-lg window-shadow z-20" style="width: 650px; height: 450px; top: 10%; left: 10%;">
        <!-- Title Bar -->
        <div id="terminal-titlebar" class="h-8 bg-slate-800 rounded-t-lg flex items-center justify-between px-3 cursor-move border-b border-slate-700">
            <div class="flex space-x-2">
                <button class="w-3 h-3 rounded-full bg-red-500 hover:bg-red-600 transition-colors" onclick="os.closeTerminal()"></button>
                <button class="w-3 h-3 rounded-full bg-yellow-500 hover:bg-yellow-600 transition-colors" onclick="os.maximizeTerminal()"></button>
                <button class="w-3 h-3 rounded-full bg-green-500 hover:bg-green-600 transition-colors"></button>
            </div>
            <div class="text-xs font-medium text-slate-400 terminal-font" id="terminal-title">user@webos: ~</div>
            <div class="w-10"></div> <!-- Spacer for centering -->
        </div>

        <!-- Terminal Content -->
        <div class="flex-1 p-2 overflow-hidden flex flex-col relative" onclick="document.getElementById('terminal-input').focus()">
            <div id="terminal-output" class="flex-1 overflow-y-auto terminal-font text-sm text-slate-300 whitespace-pre-wrap break-words pb-2"></div>
            
            <div class="flex items-center terminal-font text-sm w-full mt-1">
                <span id="terminal-prompt" class="text-green-400 font-bold mr-2 whitespace-nowrap">user@webos:~$</span>
                <input type="text" id="terminal-input" class="flex-1 bg-transparent border-none outline-none text-slate-200 terminal-font" autocomplete="off" spellcheck="false">
            </div>
        </div>
    </div>

    <!-- File Explorer Window -->
    <div id="filemgr-window" class="absolute hidden flex-col bg-slate-900 border border-slate-700 rounded-lg window-shadow z-20" style="width: 550px; height: 400px; top: 12%; left: 12%;">
        <div id="filemgr-titlebar" class="h-8 bg-slate-800 rounded-t-lg flex items-center justify-between px-3 cursor-move border-b border-slate-700">
            <div class="flex space-x-2">
                <button class="w-3 h-3 rounded-full bg-red-500 hover:bg-red-600 transition-colors" onclick="os.closeFileManager()"></button>
            </div>
            <div class="text-xs font-medium text-slate-400 terminal-font">File Manager</div>
            <div class="w-10"></div>
        </div>
        <div class="h-10 border-b border-slate-700 flex items-center px-3 bg-slate-800 gap-2">
            <button class="text-xs bg-slate-700 hover:bg-slate-600 px-2 py-1 rounded text-white" onclick="os.fileMgrGoUp()">⬆️ Up</button>
            <input id="filemgr-path" type="text" class="flex-1 bg-slate-900 text-slate-300 text-xs px-2 py-1 border border-slate-600 rounded outline-none" readonly>
            <button class="text-xs bg-yellow-600 hover:bg-yellow-500 px-2 py-1 rounded text-white font-bold" onclick="os.fileMgrNewFile('.js')">+ JS</button>
            <button class="text-xs bg-blue-600 hover:bg-blue-500 px-2 py-1 rounded text-white font-bold" onclick="os.fileMgrNewFile('.py')">+ PY</button>
            <button class="text-xs bg-orange-600 hover:bg-orange-500 px-2 py-1 rounded text-white font-bold" onclick="os.fileMgrNewFile('.html')">+ HTML</button>
            <button class="text-xs bg-slate-600 hover:bg-slate-500 px-2 py-1 rounded text-white font-bold" onclick="os.fileMgrNewFolder()">+ Dir</button>
        </div>
        <div id="filemgr-content" class="flex-1 p-4 overflow-y-auto flex flex-wrap content-start gap-4">
            <!-- Files appear here -->
        </div>
    </div>

    <!-- VS QD Code Editor -->
    <div id="vsqd-window" class="absolute hidden flex-col bg-[#1e1e1e] border border-slate-700 rounded-lg window-shadow z-20" style="width: 600px; height: 450px; top: 15%; left: 15%;">
        <div id="vsqd-titlebar" class="h-8 bg-[#2d2d2d] rounded-t-lg flex items-center justify-between px-3 cursor-move border-b border-[#3c3c3c]">
            <div class="flex space-x-2">
                <button class="w-3 h-3 rounded-full bg-red-500 hover:bg-red-600 transition-colors" onclick="os.closeVSQD()"></button>
            </div>
            <div class="text-xs font-medium text-slate-300 terminal-font">VS QD - <span id="vsqd-title">file</span></div>
            <div class="w-10"></div>
        </div>
        <div class="flex-1 flex flex-col h-full overflow-hidden">
            <textarea id="vsqd-textarea" class="flex-1 bg-[#1e1e1e] text-[#d4d4d4] p-3 outline-none border-none resize-none terminal-font text-sm leading-relaxed" spellcheck="false" placeholder="// Write code here..."></textarea>
            
            <div id="vsqd-console-wrapper" class="h-28 border-t border-[#3c3c3c] bg-[#000000] flex flex-col">
                <div class="text-[10px] text-slate-500 px-2 py-1 bg-[#1e1e1e] uppercase tracking-wider font-bold">Terminal Output</div>
                <div id="vsqd-console" class="flex-1 text-[#4af626] terminal-font text-xs p-2 overflow-y-auto whitespace-pre-wrap"></div>
            </div>

            <div class="h-10 border-t border-[#3c3c3c] flex items-center justify-between px-3 bg-[#007acc] rounded-b-lg">
                <span class="text-xs text-white font-medium" id="vsqd-status">Ready.</span>
                <div class="flex gap-2">
                    <button class="px-3 py-1 bg-green-500 hover:bg-green-400 rounded text-xs font-bold text-white transition-colors" onclick="os.runVSQD()">▶ Run Code</button>
                    <button class="px-3 py-1 bg-white hover:bg-slate-200 text-[#007acc] rounded text-xs font-bold transition-colors" onclick="os.saveVSQD()">Save File</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Web Browser Window -->
    <div id="browser-window" class="absolute hidden flex-col bg-slate-100 border border-slate-400 rounded-lg window-shadow z-20" style="width: 700px; height: 500px; top: 18%; left: 18%;">
        <div id="browser-titlebar" class="h-8 bg-slate-300 rounded-t-lg flex items-center justify-between px-3 cursor-move border-b border-slate-400">
            <div class="flex space-x-2">
                <button class="w-3 h-3 rounded-full bg-red-500 hover:bg-red-600 transition-colors" onclick="os.closeBrowser()"></button>
                <button class="w-3 h-3 rounded-full bg-yellow-500 hover:bg-yellow-600 transition-colors" onclick="os.maximizeBrowser()"></button>
                <button class="w-3 h-3 rounded-full bg-green-500 hover:bg-green-600 transition-colors"></button>
            </div>
            <div class="text-xs font-medium text-slate-700 terminal-font" id="browser-title">Web Browser</div>
            <div class="w-10"></div>
        </div>
        <div class="flex-1 bg-white flex flex-col relative rounded-b-lg overflow-hidden">
            <iframe id="browser-iframe" class="w-full h-full border-none bg-white" sandbox="allow-scripts allow-modals"></iframe>
        </div>
    </div>

    <!-- Custom Alert Box -->
    <div id="alert-box" class="absolute hidden top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-slate-800 border border-slate-600 rounded-lg shadow-2xl z-50 w-80 flex-col overflow-hidden">
        <div class="bg-slate-700 px-3 py-2 text-sm font-bold flex justify-between items-center cursor-move" id="alert-titlebar">
            <span id="alert-title">Notice</span>
            <button class="text-slate-400 hover:text-white" onclick="document.getElementById('alert-box').classList.add('hidden')">✕</button>
        </div>
        <div class="p-4 text-sm text-slate-300" id="alert-message"></div>
        <div class="bg-slate-900/50 p-2 flex justify-end">
            <button class="px-4 py-1 bg-blue-600 hover:bg-blue-500 rounded text-sm font-medium transition-colors" onclick="document.getElementById('alert-box').classList.add('hidden')">OK</button>
        </div>
    </div>

    <!-- Taskbar -->
    <div class="absolute bottom-0 w-full h-12 bg-slate-900/90 backdrop-blur-md border-t border-slate-700/50 z-30 flex items-center px-2 shadow-[0_-5px_15px_rgba(0,0,0,0.3)]">
        <button class="h-8 w-8 flex items-center justify-center rounded hover:bg-white/10 transition-colors group">
            <span class="text-xl group-hover:scale-110 transition-transform">🐧</span>
        </button>
        
        <div class="w-px h-6 bg-slate-700 mx-2"></div>
        
        <div id="taskbar-apps" class="flex-1 flex items-center gap-1">
            <!-- Open apps appear here -->
        </div>

        <button class="h-8 w-8 flex items-center justify-center rounded hover:bg-white/10 transition-colors group mx-1" onclick="document.getElementById('sys-file-upload').click()" title="Upload Image to Desktop">
            <span class="text-xl group-hover:scale-110 transition-transform">🖼️</span>
        </button>

        <div class="flex items-center gap-4 px-2">
            <div class="flex items-center gap-2 text-slate-400 text-sm">
                <span>🔊</span>
                <span>📶</span>
            </div>
            <div id="clock" class="text-xs font-medium text-slate-200"></div>
        </div>
    </div>

    <script>
        // --- Virtual File System ---
        class VirtualFileSystem {
            constructor() {
                this.root = {
                    type: 'dir',
                    contents: {
                        'home': {
                            type: 'dir',
                            contents: {
                                'user': {
                                    type: 'dir',
                                    contents: {
                                        'Desktop': {
                                            type: 'dir',
                                            contents: {
                                                'readme.txt': { type: 'file', content: 'Welcome to the WebOS Terminal.\nTry running commands like ls, pwd, mkdir, touch, cat, echo, nano, and neofetch!\n\nI am synced to your desktop visually!' }
                                            }
                                        },
                                        'projects': { type: 'dir', contents: {} },
                                        '.bashrc': { type: 'file', content: 'alias ll="ls -la"' }
                                    }
                                }
                            }
                        },
                        'bin': { type: 'dir', contents: {} },
                        'etc': { type: 'dir', contents: {} },
                        'var': { type: 'dir', contents: {} }
                    }
                };
            }

            resolvePath(currentPath, targetPath) {
                if (!targetPath) return currentPath;
                let parts = targetPath.startsWith('/') ? targetPath.split('/') : (currentPath + '/' + targetPath).split('/');
                let resolved = [];
                for (let p of parts) {
                    if (p === '' || p === '.') continue;
                    if (p === '..') {
                        if (resolved.length > 0) resolved.pop();
                    } else {
                        resolved.push(p);
                    }
                }
                return '/' + resolved.join('/');
            }

            getNode(path) {
                if (path === '/' || path === '') return this.root;
                let parts = path.split('/').filter(p => p !== '');
                let current = this.root;
                for (let p of parts) {
                    if (current.type !== 'dir' || !(p in current.contents)) return null;
                    current = current.contents[p];
                }
                return current;
            }

            getParentNodeAndName(path) {
                if (path === '/') return null;
                let resolvedPath = this.resolvePath('/', path);
                let parts = resolvedPath.split('/').filter(p => p !== '');
                let name = parts.pop();
                let parentPath = '/' + parts.join('/');
                let parentNode = this.getNode(parentPath);
                return { parentNode, name };
            }
        }

        // --- Terminal Logic ---
        class Terminal {
            constructor(vfs) {
                this.vfs = vfs;
                this.cwd = '/home/user/Desktop';
                this.user = 'user';
                this.hostname = 'vq-mq';
                this.history = [];
                this.historyIndex = -1;
                
                this.outputEl = document.getElementById('terminal-output');
                this.inputEl = document.getElementById('terminal-input');
                this.promptEl = document.getElementById('terminal-prompt');
                this.titleEl = document.getElementById('terminal-title');
                
                this.updatePrompt();
                this.setupEvents();
            }

            updatePrompt() {
                let displayPath = this.cwd.startsWith('/home/user') 
                    ? this.cwd.replace('/home/user', '~') 
                    : this.cwd;
                let prompt = `${this.user}@${this.hostname}:${displayPath}$`;
                this.promptEl.textContent = prompt;
                this.titleEl.textContent = prompt.slice(0, -1);
            }

            print(text, type = 'normal') {
                const div = document.createElement('div');
                div.className = 'mb-1';
                if (type === 'error') div.classList.add('text-red-400');
                if (type === 'success') div.classList.add('text-green-400');
                if (type === 'info') div.classList.add('text-blue-400');
                
                // Handle basic HTML injection safely for specific formatting if needed
                if (type === 'raw') {
                    div.innerHTML = text;
                } else {
                    div.textContent = text;
                }
                
                this.outputEl.appendChild(div);
                this.scrollToBottom();
            }

            printPrompt(command) {
                const div = document.createElement('div');
                div.className = 'mb-1';
                div.innerHTML = `<span class="text-green-400 font-bold">${this.promptEl.textContent}</span> <span class="text-slate-200">${this.escapeHtml(command)}</span>`;
                this.outputEl.appendChild(div);
            }

            escapeHtml(unsafe) {
                return unsafe
                     .replace(/&/g, "&amp;")
                     .replace(/</g, "&lt;")
                     .replace(/>/g, "&gt;")
                     .replace(/"/g, "&quot;")
                     .replace(/'/g, "&#039;");
            }

            scrollToBottom() {
                this.outputEl.scrollTop = this.outputEl.scrollHeight;
            }

            setupEvents() {
                this.inputEl.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        const cmd = this.inputEl.value.trim();
                        this.printPrompt(cmd);
                        this.inputEl.value = '';
                        
                        if (cmd) {
                            this.history.push(cmd);
                            this.historyIndex = this.history.length;
                            this.execute(cmd);
                        } else {
                            this.scrollToBottom();
                        }
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        if (this.historyIndex > 0) {
                            this.historyIndex--;
                            this.inputEl.value = this.history[this.historyIndex];
                        }
                    } else if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        if (this.historyIndex < this.history.length - 1) {
                            this.historyIndex++;
                            this.inputEl.value = this.history[this.historyIndex];
                        } else {
                            this.historyIndex = this.history.length;
                            this.inputEl.value = '';
                        }
                    }
                });
            }

            execute(commandStr) {
                let args = commandStr.match(/(?:[^\s"]+|"[^"]*")+/g) || [];
                args = args.map(arg => arg.startsWith('"') && arg.endsWith('"') ? arg.slice(1, -1) : arg);
                
                if (args.length === 0) return;
                
                const cmd = args.shift();

                try {
                    switch (cmd) {
                        case 'help':
                            this.print('Available commands:\n  help, clear, echo, pwd, ls, cd, mkdir, touch, cat, rm, whoami, date, vsqd, nano, maito, neofetch, sudo h');
                            break;
                        case 'sudo':
                            if (args.length === 0) {
                                this.print('usage: sudo -h | -K | -k | -V', 'error');
                                return;
                            }
                            if (args[0] === 'maito') {
                                this.maito(args.slice(1));
                            } else if (args[0] === 'h') {
                                this.print('Available commands:\n  help, clear, echo, pwd, ls, cd, mkdir, touch, cat, rm, whoami, date, vsqd, nano, maito, neofetch, sudo h');
                            } else {
                                // Execute the command that follows sudo
                                let cmdWithoutSudo = commandStr.replace(/^sudo\s+/, '');
                                this.execute(cmdWithoutSudo);
                            }
                            return; // Stop here so we don't duplicate the prompt
                        case 'maito':
                            this.print('Permission denied. You must use "sudo maito <imagename>" to change the wallpaper.', 'error');
                            break;
                        case 'clear':
                            this.outputEl.innerHTML = '';
                            break;
                        case 'echo':
                            this.print(args.join(' '));
                            break;
                        case 'pwd':
                            this.print(this.cwd);
                            break;
                        case 'whoami':
                            this.print(this.user);
                            break;
                        case 'date':
                            this.print(new Date().toString());
                            break;
                        case 'ls':
                            this.ls(args);
                            break;
                        case 'cd':
                            this.cd(args);
                            break;
                        case 'mkdir':
                            this.mkdir(args);
                            break;
                        case 'touch':
                            this.touch(args);
                            break;
                        case 'cat':
                            this.cat(args);
                            break;
                        case 'rm':
                            this.rm(args);
                            break;
                        case 'nano':
                        case 'vsqd':
                            this.vsqd(args);
                            break;
                        case 'neofetch':
                            this.neofetch();
                            break;
                        default:
                            this.print(`${cmd}: command not found`, 'error');
                    }
                } catch (e) {
                    this.print(`Error: ${e.message}`, 'error');
                }
                this.updatePrompt();
            }

            // Command Implementations
            ls(args) {
                let showHidden = args.includes('-a') || args.includes('-la') || args.includes('-al');
                let longFormat = args.includes('-l') || args.includes('-la') || args.includes('-al');
                
                let targetDir = this.cwd;
                let positionalArgs = args.filter(a => !a.startsWith('-'));
                if (positionalArgs.length > 0) {
                    targetDir = this.vfs.resolvePath(this.cwd, positionalArgs[0]);
                }

                let node = this.vfs.getNode(targetDir);
                if (!node) {
                    this.print(`ls: cannot access '${targetDir}': No such file or directory`, 'error');
                    return;
                }
                if (node.type !== 'dir') {
                    this.print(positionalArgs[0]);
                    return;
                }

                let items = Object.keys(node.contents).sort();
                if (!showHidden) {
                    items = items.filter(i => !i.startsWith('.'));
                }

                if (items.length === 0) return;

                if (longFormat) {
                    let out = items.map(item => {
                        let isDir = node.contents[item].type === 'dir';
                        let perms = isDir ? 'drwxr-xr-x' : '-rw-r--r--';
                        let size = isDir ? '4096' : (node.contents[item].content?.length || 0);
                        let colorClass = isDir ? 'text-blue-400 font-bold' : 'text-slate-300';
                        return `${perms} 1 user user ${size.toString().padStart(5)} Jan 1 00:00 <span class="${colorClass}">${item}</span>`;
                    }).join('\n');
                    this.print(out, 'raw');
                } else {
                    let out = items.map(item => {
                        let isDir = node.contents[item].type === 'dir';
                        let colorClass = isDir ? 'text-blue-400 font-bold' : 'text-slate-300';
                        return `<span class="${colorClass}">${item}</span>`;
                    }).join('  ');
                    this.print(out, 'raw');
                }
            }

            cd(args) {
                if (args.length === 0) {
                    this.cwd = '/home/user';
                    return;
                }
                let targetPath = this.vfs.resolvePath(this.cwd, args[0]);
                let node = this.vfs.getNode(targetPath);
                
                if (!node) {
                    this.print(`cd: ${args[0]}: No such file or directory`, 'error');
                } else if (node.type !== 'dir') {
                    this.print(`cd: ${args[0]}: Not a directory`, 'error');
                } else {
                    this.cwd = targetPath;
                }
            }

            mkdir(args) {
                if (args.length === 0) {
                    this.print('mkdir: missing operand', 'error');
                    return;
                }
                let { parentNode, name } = this.vfs.getParentNodeAndName(this.vfs.resolvePath(this.cwd, args[0]));
                
                if (!parentNode) {
                    this.print(`mkdir: cannot create directory '${args[0]}': No such file or directory`, 'error');
                    return;
                }
                if (parentNode.type !== 'dir') {
                    this.print(`mkdir: cannot create directory '${args[0]}': Not a directory`, 'error');
                    return;
                }
                if (name in parentNode.contents) {
                    this.print(`mkdir: cannot create directory '${args[0]}': File exists`, 'error');
                    return;
                }
                
                parentNode.contents[name] = { type: 'dir', contents: {} };
                this.print(`Directory '${args[0]}' created successfully.`, 'success');
                os.renderDesktop();
            }

            touch(args) {
                if (args.length === 0) {
                    this.print('touch: missing file operand', 'error');
                    return;
                }
                let { parentNode, name } = this.vfs.getParentNodeAndName(this.vfs.resolvePath(this.cwd, args[0]));
                
                if (parentNode && parentNode.type === 'dir') {
                    if (!(name in parentNode.contents)) {
                        parentNode.contents[name] = { type: 'file', content: '' };
                        this.print(`File '${args[0]}' created successfully.`, 'success');
                        os.renderDesktop();
                    } else {
                        this.print(`touch: updated timestamp for '${args[0]}'`, 'info');
                    }
                }
            }

            cat(args) {
                if (args.length === 0) {
                    this.print('cat: missing file operand', 'error');
                    return;
                }
                let targetPath = this.vfs.resolvePath(this.cwd, args[0]);
                let node = this.vfs.getNode(targetPath);
                
                if (!node) {
                    this.print(`cat: ${args[0]}: No such file or directory`, 'error');
                } else if (node.type === 'dir') {
                    this.print(`cat: ${args[0]}: Is a directory`, 'error');
                } else {
                    this.print(node.content);
                }
            }

            rm(args) {
                if (args.length === 0) {
                    this.print('rm: missing operand', 'error');
                    return;
                }
                let targetPath = this.vfs.resolvePath(this.cwd, args[0]);
                
                if (targetPath === '/' || targetPath === '/home' || targetPath === '/home/user') {
                    this.print(`rm: cannot remove '${args[0]}': Permission denied`, 'error');
                    return;
                }

                let { parentNode, name } = this.vfs.getParentNodeAndName(targetPath);
                
                if (!parentNode || !(name in parentNode.contents)) {
                    this.print(`rm: cannot remove '${args[0]}': No such file or directory`, 'error');
                    return;
                }

                let node = parentNode.contents[name];
                if (node.type === 'dir' && !args.includes('-r') && !args.includes('-rf')) {
                    this.print(`rm: cannot remove '${args[0]}': Is a directory`, 'error');
                    return;
                }

                delete parentNode.contents[name];
                this.print(`Removed '${args[0]}' successfully.`, 'success');
                os.renderDesktop();
                if (os.currentFileMgrPath === parentNode) os.renderFileManager(targetPath.substring(0, targetPath.lastIndexOf('/')));
            }

            maito(args) {
                // Join arguments in case the user typed a file name with spaces but forgot quotes
                const fileName = args.join(' ');
                
                if (!fileName) {
                    this.print('sudo maito: missing image name', 'error');
                    return;
                }
                
                let targetPath = this.vfs.resolvePath(this.cwd, fileName);
                let node = this.vfs.getNode(targetPath);
                
                if (!node || node.type !== 'file') {
                    this.print(`maito: ${fileName}: Image file not found. Did you upload it?`, 'error');
                    return;
                }
                if (!node.content.startsWith('data:image/')) {
                    this.print(`maito: ${fileName}: Not a valid uploaded image`, 'error');
                    return;
                }
                
                document.getElementById('desktop-bg').style.backgroundImage = `url('${node.content}')`;
                this.print(`Desktop wallpaper successfully changed to ${fileName}!`, 'success');
            }

            vsqd(args) {
                if (args.length === 0) {
                    this.print('vsqd: missing filename', 'error');
                    return;
                }
                let targetPath = this.vfs.resolvePath(this.cwd, args[0]);
                let node = this.vfs.getNode(targetPath);
                
                if (node && node.type === 'dir') {
                    this.print(`vsqd: ${args[0]} is a directory`, 'error');
                    return;
                }
                
                os.openVSQD(targetPath);
                this.print(`Opening VS QD for '${args[0]}'...`, 'info');
            }

