            fileMgrNewFile(ext = '.js') {
                let baseName = ext === '.js' ? 'script' : (ext === '.py' ? 'main' : 'index');
                const name = `${baseName}_${Math.floor(Math.random()*100)}${ext}`;
                const node = this.vfs.getNode(this.currentFileMgrPath);
                if (node && node.type === 'dir') {
                    if (node.contents[name]) return;
                    let content = '';
                    if (ext === '.js') content = 'console.log("Hello JS!");\n';
                    if (ext === '.py') content = 'print("Hello from Python!")\n';
                    if (ext === '.html') content = '<h1>Hello WebOS!</h1>\n<p>This is live rendered HTML.</p>';

                    node.contents[name] = { type: 'file', content: content };
                    this.renderFileManager(this.currentFileMgrPath);
                    if (this.currentFileMgrPath === '/home/user/Desktop') this.renderDesktop();
