        // --- Window Management ---
        class WindowManager {
            constructor() {
                this.zIndexCounter = 20;
                this.makeDraggable(document.getElementById('terminal-window'), document.getElementById('terminal-titlebar'));
                this.makeDraggable(document.getElementById('vsqd-window'), document.getElementById('vsqd-titlebar'));
                this.makeDraggable(document.getElementById('filemgr-window'), document.getElementById('filemgr-titlebar'));
                this.makeDraggable(document.getElementById('browser-window'), document.getElementById('browser-titlebar'));
                this.makeDraggable(document.getElementById('alert-box'), document.getElementById('alert-titlebar'));
            }

            makeDraggable(elmnt, header) {
                let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
                
                header.onmousedown = dragMouseDown;
                header.ontouchstart = dragTouchStart;

                const bringToFront = () => {
                    this.zIndexCounter++;
                    elmnt.style.zIndex = this.zIndexCounter;
                };

                elmnt.addEventListener('mousedown', bringToFront);
                elmnt.addEventListener('touchstart', bringToFront);

                function dragMouseDown(e) {
                    e = e || window.event;
                    e.preventDefault();
                    pos3 = e.clientX;
                    pos4 = e.clientY;
                    document.onmouseup = closeDragElement;
                    document.onmousemove = elementDrag;
                }

                function dragTouchStart(e) {
                    e = e || window.event;
                    pos3 = e.touches[0].clientX;
                    pos4 = e.touches[0].clientY;
                    document.ontouchend = closeDragElement;
                    document.ontouchmove = elementDragTouch;
                }

                function elementDrag(e) {
                    e = e || window.event;
                    e.preventDefault();
                    pos1 = pos3 - e.clientX;
                    pos2 = pos4 - e.clientY;
                    pos3 = e.clientX;
                    pos4 = e.clientY;
                    elmnt.style.top = (elmnt.offsetTop - pos2) + "px";
                    elmnt.style.left = (elmnt.offsetLeft - pos1) + "px";
                }

                function elementDragTouch(e) {
                    e = e || window.event;
                    pos1 = pos3 - e.touches[0].clientX;
                    pos2 = pos4 - e.touches[0].clientY;
                    pos3 = e.touches[0].clientX;
                    pos4 = e.touches[0].clientY;
                    elmnt.style.top = (elmnt.offsetTop - pos2) + "px";
                    elmnt.style.left = (elmnt.offsetLeft - pos1) + "px";
                }

                function closeDragElement() {
                    document.onmouseup = null;
                    document.onmousemove = null;
                    document.ontouchend = null;
                    document.ontouchmove = null;
                }
            }
        }

