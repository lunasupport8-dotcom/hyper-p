                const reader = new FileReader();
                reader.onload = (e) => {
                    const dataUrl = e.target.result;
                    const desktopPath = '/home/user/Desktop';
                    const desktopNode = this.vfs.getNode(desktopPath);
                    
                    desktopNode.contents[file.name] = { type: 'file', content: dataUrl };
                    
                    this.renderDesktop();
                    if (this.currentFileMgrPath === desktopPath) this.renderFileManager(desktopPath);
                    this.alert('Upload Successful', `Image ${file.name} saved to Desktop.\nTry typing 'sudo maito "${file.name}"' in the terminal!`);
